{
  "expo": {
    "name": "FisioFlow Paciente",
    "slug": "fisioflow-patient",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "fisioflow",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D9488"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fisioflow.patients",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Permitir acesso a camera para fotos de perfil e exercicios",
        "NSPhotoLibraryUsageDescription": "Permitir acesso a galeria para selecionar fotos",
        "NSMicrophoneUsageDescription": "Permitir acesso ao microfone para gravar videos de exercicios",
        "NSCalendarsUsageDescription": "O FisioFlow precisa de acesso ao seu calendário para sincronizar suas sessões de fisioterapia automaticamente.",
        "NSRemindersUsageDescription": "O FisioFlow precisa de acesso aos seus lembretes para avisar sobre o horário das suas sessões.",
        "NSHealthShareUsageDescription": "O FisioFlow acessa seus dados de saúde (passos, batimentos, sono) para compartilhar com seu fisioterapeuta e acompanhar sua evolução clínica.",
        "NSHealthUpdateUsageDescription": "O FisioFlow não grava dados no app Saúde."
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D9488"
      },
      "package": "com.fisioflow.patient",
      "versionCode": 1,
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.READ_DISTANCE",
        "android.permission.health.READ_SLEEP"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-calendar",
      "./plugins/withSwiftConcurrency",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0D9488"
        }
      ],
      "expo-audio",
      "expo-localization",
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true,
      "asyncRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "3dc7141f-4e97-4c2c-b4aa-959888a0e810"
      }
    },
    "owner": "rafaelminatto",
    "updates": {
      "enabled": true,
      "url": "https://u.expo.dev/3dc7141f-4e97-4c2c-b4aa-959888a0e810",
      "enableBsdiffPatchSupport": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}

{
  "name": "fisioflow-patient-ios",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:dev-client": "expo start --dev-client",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "build": "tsc --noEmit",
    "build:dev": "eas build --profile development --platform ios",
    "build:dev:android": "eas build --profile development --platform android",
    "build:preview": "eas build --profile preview --platform ios",
    "build:prod": "eas build --profile production --platform ios",
    "submit": "eas submit --platform ios",
    "type-check": "tsc --noEmit",
    "test": "pnpm exec jest",
    "test:unit": "pnpm exec jest",
    "test:watch": "pnpm exec jest --watch",
    "test:coverage": "pnpm exec jest --coverage",
    "lint": "oxlint . --quiet",
    "lint:fix": "oxlint . --fix"
  },

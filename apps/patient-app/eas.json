{
  "cli": {
    "version": ">= 12.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "development:simulator": {
      "developmentClient": true,
      "distribution": "internal",
      "image": "macos-sequoia-15.4-xcode-16.3-1",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "env": {
        "APP_ENV": "preview"
      }
    },
    "testflight": {
      "distribution": "internal",
      "ios": {
        "autoIncrement": true
      },
      "env": {
        "APP_ENV": "testflight"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {},
      "env": {
        "APP_ENV": "production"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "rafael.minatto@yahoo.com.br",
        "appName": "FisioFlow Paciente",
        "ascAppId": "6504123457",
        "appleTeamId": "G7FDW933SF"
      }
    }
  }
}

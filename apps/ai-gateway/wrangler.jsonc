{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "fisioflow-ai-gateway",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-12",
  "observability": {
    "enabled": true
  },
  "placement": {
    "mode": "smart"
  },
  "analytics_engine_datasets": [
    {
      "binding": "ANALYTICS",
      "dataset": "fisioflow_ai_usage"
    }
  ],
  "vars": {
    "ENVIRONMENT": "production",
    "ALLOWED_ORIGINS": "https://moocafisio.com.br,https://www.moocafisio.com.br,https://fisioflow.pages.dev,http://localhost:5173",
    "GOOGLE_AI_URL": "https://generativelanguage.googleapis.com/v1beta/models",
    "OLLAMA_ENDPOINT": "https://ollama.moocafisio.com.br"
  },
  "env": {
    "staging": {
      "vars": {
        "ENVIRONMENT": "staging",
        "ALLOWED_ORIGINS": "https://fisioflow-web-staging.rafalegollas.workers.dev,http://localhost:5173",
        "GOOGLE_AI_URL": "https://generativelanguage.googleapis.com/v1beta/models",
        "OLLAMA_ENDPOINT": "https://ollama-staging.moocafisio.com.br"
      },
      "analytics_engine_datasets": [
        { "binding": "ANALYTICS", "dataset": "fisioflow_ai_usage" }
      ]
    },
    "production": {
      "name": "fisioflow-ai-gateway",
      "vars": {
        "ENVIRONMENT": "production",
        "ALLOWED_ORIGINS": "https://moocafisio.com.br,https://www.moocafisio.com.br,https://fisioflow.pages.dev,http://localhost:5173",
        "GOOGLE_AI_URL": "https://generativelanguage.googleapis.com/v1beta/models",
        "OLLAMA_ENDPOINT": "https://ollama.moocafisio.com.br"
      },
      "analytics_engine_datasets": [
        { "binding": "ANALYTICS", "dataset": "fisioflow_ai_usage" }
      ]
    }
  }
}

# Cloudflare Workers Static Assets — regras de header.
# https://developers.cloudflare.com/workers/static-assets/headers/
#
# IMPORTANTE: arquivos estáticos são servidos DIRETO pela camada de assets do
# Cloudflare, SEM invocar o asset-worker.ts (run_worker_first=false). Portanto o
# cache destes é controlado 100% aqui — o applyCacheHeaders() do worker só vale
# para SPA fallback / neon-auth / 404. O default do CF p/ assets já é
# "max-age=0, must-revalidate", então NÃO definimos Cache-Control no /* (isso
# evita o header duplicado que fazia o browser revalidar até os assets imutáveis
# a cada navegação — tempestade de 304 no SPA/visitas repetidas).

# Assets com hash no nome (Vite) — conteúdo imutável, cache máximo.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Fontes self-hosted (nomes estáveis, mudam ~nunca). Trocar fonte = renomear.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# CSS do design system — o HTML referencia com ?v=BUILD_TIME (cache-buster),
# então cada deploy vira uma URL nova; seguro cachear longo.
/styles/*
  Cache-Control: public, max-age=31536000, immutable

# Ícones do PWA — estáveis, cache de 30 dias.
/icons/*
  Cache-Control: public, max-age=2592000

# Demais respostas (HTML etc.): sem Cache-Control aqui de propósito → assume o
# default do Cloudflare (max-age=0, must-revalidate). Só headers de segurança.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin

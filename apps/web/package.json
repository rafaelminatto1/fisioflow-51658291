{
  "name": "fisioflow-web",
  "private": true,
  "version": "0.0.2",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "predev": "pnpm --dir ../.. exec node scripts/ensure-vite-cache.cjs",
    "dev": "pnpm --dir ../.. exec vite apps/web --config apps/web/vite.config.ts",
    "dev:web": "pnpm --dir ../.. exec vite apps/web --config apps/web/vite.config.ts",
    "dev:clean": "pnpm --dir ../.. exec node scripts/clean-vite-cache.cjs && pnpm --dir ../.. exec vite apps/web --config apps/web/vite.config.ts",
    "dev:force": "pnpm --dir ../.. exec vite apps/web --config apps/web/vite.config.ts --force",
    "clean:vite": "pnpm --dir ../.. exec node scripts/clean-vite-cache.cjs",
    "build": "NODE_OPTIONS='--max-old-space-size=4096' pnpm --dir ../.. exec vite build apps/web --config apps/web/vite.config.ts",
    "build:prod": "NODE_OPTIONS='--max-old-space-size=4096' pnpm --dir ../.. exec vite build apps/web --config apps/web/vite.config.ts",
    "build:dev": "pnpm --dir ../.. exec vite build apps/web --config apps/web/vite.config.ts --mode development",
    "build:analyze": "NODE_OPTIONS='--max-old-space-size=4096' ANALYZE=true pnpm --dir ../.. exec vite build apps/web --config apps/web/vite.config.ts",
    "lint": "pnpm --dir ../.. exec oxlint --quiet",
    "lint:fix": "pnpm --dir ../.. exec oxlint --fix",
    "fmt": "pnpm --dir ../.. exec oxfmt",
    "fmt:check": "pnpm --dir ../.. exec oxfmt --check",
    "preview": "pnpm --dir ../.. exec vite preview apps/web --config apps/web/vite.config.ts",
    "test": "pnpm --dir ../.. exec vitest --config apps/web/vitest.config.ts",
    "test:unit": "pnpm --dir ../.. exec vitest run --config apps/web/vitest.config.ts",
    "test:ui": "pnpm --dir ../.. exec vitest --ui --config apps/web/vitest.config.ts",
    "test:run": "pnpm --dir ../.. exec vitest run --config apps/web/vitest.config.ts",
    "test:coverage": "pnpm --dir ../.. exec vitest run --config apps/web/vitest.config.ts --coverage",
    "test:e2e": "pnpm --dir ../.. exec playwright test --config apps/web/playwright.config.ts",
    "test:e2e:ci": "pnpm --dir ../.. exec playwright test --config apps/web/playwright.config.ts --workers=1",
    "test:e2e:headed": "pnpm --dir ../.. exec playwright test --config apps/web/playwright.config.ts --headed",
    "test:e2e:debug": "pnpm --dir ../.. exec playwright test --config apps/web/playwright.config.ts --debug",
    "test:e2e:auth": "pnpm --dir ../.. exec playwright test --config apps/web/playwright.config.ts e2e/auth.spec.ts --project=chromium",
    "test:e2e:dashboard": "pnpm --dir ../.. exec playwright test --config apps/web/playwright.config.ts e2e/dashboard.spec.ts --project=chromium",
    "test:e2e:patients": "pnpm --dir ../.. exec playwright test --config apps/web/playwright.config.ts e2e/patients.spec.ts --project=chromium",
    "test:e2e:agenda": "pnpm --dir ../.. exec playwright test --config apps/web/playwright.config.ts e2e/agenda.spec.ts --project=chromium",
    "test:e2e:agenda-optimistic": "E2E_SKIP_AUTH_SETUP=true pnpm --dir ../.. exec playwright test --config apps/web/playwright.config.ts e2e/agenda-optimistic-reschedule.spec.ts --project=chromium --workers=1",
    "test:e2e:agenda-regression": "pnpm --dir ../.. exec playwright test --config apps/web/playwright.config.ts --project=chromium --workers=1 e2e/agenda-dnd.spec.ts e2e/agenda-grid-stability.spec.ts",
    "test:e2e:ui": "pnpm --dir ../.. exec playwright test --config apps/web/playwright.config.ts --ui",
    "test:e2e:auto": "E2E_AUTO_SEED=true pnpm --dir ../.. exec playwright test --config apps/web/playwright.config.ts",
    "test:e2e:auto:ui": "E2E_AUTO_SEED=true pnpm --dir ../.. exec playwright test --config apps/web/playwright.config.ts --ui",
    "test:e2e:critical": "pnpm --dir ../.. exec playwright test --config apps/web/playwright.config.ts e2e/critical-flows.spec.ts e2e/deploy-gate.spec.ts e2e/auth.spec.ts e2e/patients.spec.ts e2e/agenda.spec.ts e2e/financial.spec.ts --project=chromium --workers=1",
    "test:e2e:deploy-gate": "pnpm --dir ../.. exec playwright test --config apps/web/playwright.config.ts e2e/deploy-gate.spec.ts --project=chromium",
    "test:e2e:a11y": "pnpm --dir ../.. exec playwright test --config apps/web/playwright.config.ts e2e/accessibility-extended.spec.ts",
    "type-check": "pnpm --dir ../.. exec tsc -p apps/web/tsconfig.json --noEmit --skipLibCheck",
    "analyze": "NODE_OPTIONS='--max-old-space-size=4096' ANALYZE=true pnpm --dir ../.. exec vite build apps/web --config apps/web/vite.config.ts",
    "storybook": "pnpm --dir ../.. exec storybook dev -c apps/web/.storybook -p 6006",
    "build-storybook": "pnpm --dir ../.. exec storybook build -c apps/web/.storybook -o apps/web/storybook-static",
    "format": "pnpm --dir ../.. exec biome format --write src"
  },

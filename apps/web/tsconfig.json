{
  "files": [],
  "references": [
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.node.json"
    }
  ],
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "paths": {
      "@/*": [
        "../../src/*"
      ],
      "@fisioflow/ui": [
        "../../packages/ui/src"
      ],
      "@fisioflow/core": [
        "../../packages/core/src"
      ],
      "@fisioflow/config": [
        "../../packages/config/src"
      ],
      "@fisioflow/skills": [
        "../../src/lib/skills"
      ],
      "@fisioflow/skills-fase1": [
        "../../src/lib/skills/fase1-changelog"
      ],
      "@fisioflow/skills-fase2": [
        "../../src/lib/skills/fase2-documentos"
      ],
      "@fisioflow/skills-fase3": [
        "../../src/lib/skills/fase3-integracoes"
      ],
      "@fisioflow/skills-fase4": [
        "../../src/lib/skills/fase4-conteudo"
      ]
    },
    "noImplicitAny": true,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "allowJs": true,
    "noUnusedLocals": false,
    "strictNullChecks": true,
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true
  }
}

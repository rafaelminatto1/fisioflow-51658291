{
  "name": "@fisioflow/api",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.0.0"
  },
  "description": "FisioFlow Cloudflare Workers API — Hono + Neon (Hyperdrive) + Drizzle",
  "scripts": {
    "dev": "sh dev.sh",
    "build": "wrangler deploy --dry-run --env production",
    "deploy": "wrangler deploy --env production",
    "deploy:staging": "wrangler deploy --env staging",
    "lint": "oxlint --quiet",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1016.0",
    "@aws-sdk/s3-request-presigner": "^3.1016.0",
    "@fisioflow/core": "workspace:*",
    "@fisioflow/db": "workspace:*",
    "@google/genai": "^1.50.1",
    "@hono/zod-validator": "^0.7.6",
    "@neondatabase/serverless": "^1.0.2",
    "agents": "^0.8.2",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.15",
    "inngest": "^3.52.3",
    "jose": "^5.10.0",
    "kysely": "^0.28.14",
    "openai": "^6.33.0",
    "pg": "^8.13.3",
    "recharts": "^2.15.4",
    "resend": "^4.8.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/puppeteer": "^1.0.6",
    "@cloudflare/workers-types": "^4.20260424.1",
    "@types/pg": "8.11.10",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.2",
    "vitest": "^4.1.5",
    "wrangler": "4.85.0"
  }
}

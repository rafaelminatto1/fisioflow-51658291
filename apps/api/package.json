{
  "name": "@fisioflow/api",
  "version": "1.0.0",
  "private": true,
  "description": "FisioFlow Cloudflare Workers API — Hono + Neon (Hyperdrive) + Drizzle",
  "scripts": {
    "dev": "sh dev.sh",
    "build": "wrangler deploy --dry-run --env production",
    "deploy": "wrangler deploy --env production",
    "deploy:staging": "wrangler deploy --env staging",
    "lint": "oxlint --quiet",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1016.0",
    "@aws-sdk/s3-request-presigner": "^3.1016.0",
    "@cloudflare/voice": "^0.2.0",
    "@fisioflow/core": "workspace:*",
    "@fisioflow/db": "workspace:*",
    "@google/genai": "^1.50.1",
    "@hono/zod-validator": "^0.8.0",
    "@neondatabase/serverless": "^1.0.2",
    "agents": "^0.15.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.24",
    "inngest": "^3.52.3",
    "jose": "^5.10.0",
    "kysely": "^0.28.14",
    "openai": "^6.33.0",
    "pg": "^8.13.3",
    "recharts": "^2.15.4",
    "resend": "^4.8.0",
    "uuid": "^13.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/puppeteer": "^1.0.6",
    "@cloudflare/workers-types": "^4.20260609.1",
    "@types/pg": "8.11.10",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "wrangler": "4.100.0"
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.0.9+sha512.34ce82e6780233cf9cad8685029a8f81d2e06196c5a9bad98879f7424940c6817c4e4524fb7d38b8553ceed48b9758b8ebaf1abd3600c232c4c8cf7366086f38"

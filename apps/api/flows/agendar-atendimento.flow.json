{
  "version": "7.3",
  "data_api_version": "3.0",
  "routing_model": { "APPOINTMENT": [] },
  "screens": [
    {
      "id": "APPOINTMENT",
      "title": "Agendar atendimento",
      "terminal": true,
      "data": {
        "types": { "type": "array", "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } }, "__example__": [{ "id": "evaluation", "title": "Avaliação" }, { "id": "session", "title": "Sessão" }] },
        "slots": { "type": "array", "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } }, "__example__": [{ "id": "08:30", "title": "08:30" }] }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "form",
            "children": [
              { "type": "Dropdown", "name": "type", "label": "Tipo de atendimento", "required": true, "data-source": "${data.types}" },
              { "type": "DatePicker", "name": "date", "label": "Data", "required": true, "on-select-action": { "name": "data_exchange", "payload": { "type": "${form.type}", "date": "${form.date}" } } },
              { "type": "Dropdown", "name": "slot", "label": "Horário disponível", "required": true, "data-source": "${data.slots}" },
              { "type": "Footer", "label": "Confirmar", "on-click-action": { "name": "complete", "payload": { "type": "${form.type}", "date": "${form.date}", "slot": "${form.slot}" } } }
            ]
          }
        ]
      }
    }
  ]
}

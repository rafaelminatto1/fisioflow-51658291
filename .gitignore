.pnp
.pnp.js
.expo/

# === Build outputs ===
dist/
dist-ssr/
build/
*.local
.next/
.nuxt/

# === Environment variables & Secrets ===
.env
.env.local
.env.development.local
.env.test
.env.test.local
.env.production.local
.env.production
.env.build
.env.dev-run
.env.yaml
.env*.local
**/.dev.vars
apps/api/.dev.vars
apps/jules-bot/.dev.vars
workers/.dev.vars.local
*.dev.vars.local

# === Wrangler ===
.wrangler/

# === Drizzle ===
drizzle/.temp

# === Database ===
*.db
*.sqlite
*.sqlite3

# === Testing & Coverage ===
coverage/
.nyc_output/
test-results/
playwright-report/
blob-report/
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright-profile/
/playwright-profile-auto/
/playwright/.auth/

# === Logs ===
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
lint_output.txt
eslint_results.txt
*storybook.log

# === Cache ===
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/
.npm/

# === Runtime ===
pids/
*.pid
*.seed
*.pid.lock
.node_repl_history

# === Editor & IDE ===
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.opencode/
.claude/
.agent/
.playwright-mcp/

# === OS generated ===
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
__pycache__/

# === Backup & temp files ===
*.bak
*.backup
*.tmp
tmp/
temp/
temp-avif-conversion/
temp-webp-conversion/
*.tgz

# === Deployment ===
.vercel/
.netlify/
storybook-static/
.out/
.storybook-out/


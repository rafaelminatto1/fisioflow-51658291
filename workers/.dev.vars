# Local development overrides for wrangler dev
# IMPORTANTE: copie este arquivo como .dev.vars.local e preencha os valores reais.
# Use `pnpm workers:dev` (via dev.sh) que injeta automaticamente a DATABASE_URL do .env raiz.

# Hyperdrive — conexão direta ao Neon para desenvolvimento local
# Obtido de: .env raiz → DATABASE_URL
WRANGLER_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE="postgresql://neondb_owner:<SENHA>@ep-wandering-bonus-acj4zwvo-pooler.sa-east-1.aws.neon.tech/neondb?sslmode=require"

# Neon Auth — verificação JWT
NEON_AUTH_JWKS_URL="https://ep-wandering-bonus-acj4zwvo.neonauth.sa-east-1.aws.neon.tech/neondb/auth/.well-known/jwks.json"
NEON_AUTH_ISSUER="https://ep-wandering-bonus-acj4zwvo.neonauth.sa-east-1.aws.neon.tech"

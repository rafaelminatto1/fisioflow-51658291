{
  "mcpServers": {
    "filesystem": {
      "command": "uvx",
      "args": ["mcp-server-filesystem", "--allowed-dirs", "src", "public", "supabase", ".kiro"],
      "disabled": false,
      "autoApprove": ["read_file", "list_directory"]
    },
    "web-search": {
      "command": "uvx",
      "args": ["mcp-server-brave-search"],
      "env": {
        "BRAVE_API_KEY": "\${BRAVE_API_KEY}"
      },
      "disabled": false,
      "autoApprove": ["search"]
    },
    "github": {
      "command": "uvx",
      "args": ["mcp-server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "\${GITHUB_API_KEY}"
      },
      "disabled": false,
      "autoApprove": ["search_repositories", "get_file_contents"]
    },
    "postgres": {
      "command": "uvx",
      "args": ["mcp-server-postgres"],
      "env": {
        "POSTGRES_CONNECTION_STRING": "\${DATABASE_URL}"
      },
      "disabled": true,
      "autoApprove": ["list_schemas", "describe_table"]
    },
    "npm": {
      "command": "uvx",
      "args": ["mcp-server-npm"],
      "disabled": true,
      "autoApprove": ["search_packages", "get_package_info"]
    },
    "memory": {
      "command": "uvx",
      "args": ["mcp-server-memory"],
      "disabled": true,
      "autoApprove": ["store_memory", "search_memory"]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"],
      "disabled": true,
      "autoApprove": ["navigate", "screenshot", "evaluate"]
    },
    "exa": {
      "type": "http",
      "url": "https://mcp.exa.ai/mcp?exaApiKey=d12af1da-4c1d-4665-a952-2bdfa6283d11",
      "disabled": false
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "ctx7sk-ad94ba7f-5d88-47b6-9c00-a478dd2b5343"
      },
      "disabled": false
    }
  }
}

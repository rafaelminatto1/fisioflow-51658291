{
	"mcpServers": {
		"shadcn": {
			"command": "npx",
			"args": ["@jpisnice/shadcn-ui-mcp-server"],
			"env": {
				"FRAMEWORK": "react",
				"GITHUB_API_KEY": "${GITHUB_API_KEY}"
			},
			"disabled": false,
			"autoApprove": ["get_components", "add_component"]
		},
		"shadcn-official": {
			"command": "npx",
			"args": ["shadcn@latest", "mcp"],
			"autoApprove": ["get_components", "add_component"]
		},
		"shadcn-community": {
			"command": "npx",
			"args": [
				"-y",
				"@jpisnice/shadcn-ui-mcp-server",
				"--framework",
				"react-native"
			],
			"autoApprove": ["get_components", "add_component"]
		},
		"supabase": {
			"command": "uvx",
			"args": ["supabase-mcp-server"],
			"env": {
				"SUPABASE_URL": "${VITE_SUPABASE_URL}",
				"SUPABASE_ANON_KEY": "${VITE_SUPABASE_ANON_KEY}"
			},
			"disabled": false,
			"autoApprove": ["list_tables", "describe_table", "query"]
		},
		"supabase-http": {
			"type": "http",
			"url": "https://mcp.supabase.com/mcp?project_ref=ycvbtjfrchcyvmkvuocu"
		},
		"postgres": {
			"command": "uvx",
			"args": ["mcp-server-postgres"],
			"env": {
				"POSTGRES_CONNECTION_STRING": "${DATABASE_URL}"
			},
			"disabled": false,
			"autoApprove": ["list_schemas", "describe_table"]
		},
		"web-search": {
			"command": "uvx",
			"args": ["mcp-server-brave-search"],
			"env": {
				"BRAVE_API_KEY": "${BRAVE_API_KEY}"
			},
			"disabled": false,
			"autoApprove": ["search"]
		},
		"github": {
			"command": "uvx",
			"args": ["mcp-server-github"],
			"env": {
				"GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_API_KEY}"
			},
			"disabled": false,
			"autoApprove": ["search_repositories", "get_file_contents"]
		},
		"filesystem": {
			"command": "uvx",
			"args": [
				"mcp-server-filesystem",
				"--allowed-dirs",
				"src",
				"public",
				"supabase",
				".kiro"
			],
			"disabled": false,
			"autoApprove": ["read_file", "list_directory"]
		},
		"npm": {
			"command": "uvx",
			"args": ["mcp-server-npm"],
			"disabled": false,
			"autoApprove": ["search_packages", "get_package_info"]
		},
		"docker": {
			"command": "uvx",
			"args": ["mcp-server-docker"],
			"disabled": false,
			"autoApprove": ["list_containers", "get_container_info"]
		},
		"memory": {
			"command": "uvx",
			"args": ["mcp-server-memory"],
			"disabled": false,
			"autoApprove": ["store_memory", "search_memory"]
		},
		"neon": {
			"type": "http",
			"url": "https://mcp.neon.tech/mcp",
			"headers": {
				"Accept": "application/json",
				"Authorization": "Bearer ${NEON_API_KEY}"
			},
			"disabled": false,
			"autoApprove": []
		},
		"time": {
			"command": "uvx",
			"args": ["mcp-server-time"],
			"disabled": false,
			"autoApprove": ["get_current_time", "format_time"]
		},
		"aws-docs": {
			"command": "uvx",
			"args": ["awslabs.aws-documentation-mcp-server@latest"],
			"env": {
				"FASTMCP_LOG_LEVEL": "ERROR"
			},
			"disabled": false,
			"autoApprove": ["search_docs", "get_documentation"]
		},
		"firebase-mcp": {
			"command": "npx",
			"args": ["-y", "@gannonh/firebase-mcp"],
			"env": {
				"SERVICE_ACCOUNT_KEY_PATH": "/home/rafael/antigravity/fisioflow/fisioflow-51658291/functions/service-account-key.json",
				"FIREBASE_STORAGE_BUCKET": "fisioflow-migration.firebasestorage.app"
			},
			"disabled": false,
			"autoApprove": []
		},
		"firebase": {
			"command": "npx",
			"args": ["-y", "firebase-tools@latest", "mcp"]
		},
		"stitch": {
			"type": "http",
			"url": "https://stitch.googleapis.com/mcp",
			"headers": {
				"Accept": "application/json",
				"X-Goog-Api-Key": "AQ.Ab8RN6KZoLwfpsQbZFwXNPvTFxgCXtOXIwG5ri_Z5KGBk3Lb3A"
			},
			"disabled": false,
			"autoApprove": []
		},
		"chrome-devtools": {
			"command": "npx",
			"args": ["-y", "chrome-devtools-mcp@latest"],
			"disabled": false,
			"autoApprove": ["navigate", "screenshot", "evaluate"]
		},
		"fisioflow-api": {
			"type": "http",
			"url": "https://api-pro.moocafisio.com.br/api"
		},
		"TestSprite": {
			"command": "npx",
			"args": ["@testsprite/testsprite-mcp@latest"],
			"env": {
				"API_KEY": "${TESTSPRITE_API_KEY}"
			},
			"disabled": false,
			"autoApprove": []
		},
		"websets": {
			"command": "npx",
			"args": [
				"-y",
				"mcp-remote",
				"https://websetsmcp.exa.ai/mcp?exaApiKey=d12af1da-4c1d-4665-a952-2bdfa6283d11"
			]
		}
	}
}

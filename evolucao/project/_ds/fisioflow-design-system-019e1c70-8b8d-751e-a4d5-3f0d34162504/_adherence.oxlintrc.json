{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "evolucao-sessao/**",
              "image-slot.js",
              "ui_kits/patient-app/**",
              "ui_kits/web/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:VAG Rounded|Futura Condensed|Nunito))/i]",
        "message": "Font not provided by the design system. Available: VAG Rounded, Futura Condensed, Nunito."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {},
    "tokens": [
      "--accent",
      "--accent-foreground",
      "--background",
      "--border",
      "--card",
      "--card-foreground",
      "--color-pain-0",
      "--color-pain-1",
      "--color-pain-10",
      "--color-pain-3",
      "--color-pain-5",
      "--color-pain-7",
      "--color-pain-gauge-high",
      "--color-pain-gauge-low",
      "--color-pain-gauge-med",
      "--color-pain-gauge-severe",
      "--color-status-cancelled",
      "--color-status-completed",
      "--color-status-confirmed",
      "--color-status-pending",
      "--destructive",
      "--destructive-foreground",
      "--font-brand",
      "--font-display",
      "--font-futura",
      "--font-mono",
      "--font-sans",
      "--foreground",
      "--input",
      "--muted",
      "--muted-foreground",
      "--popover",
      "--popover-foreground",
      "--primary",
      "--primary-foreground",
      "--radius",
      "--radius-lg",
      "--radius-md",
      "--radius-sm",
      "--ring",

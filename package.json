{
  "name": "fisioflow-monorepo",
  "version": "0.0.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bash scripts/cloudflare-env.sh turbo dev --filter=fisioflow-web --filter=@fisioflow/api",
    "build": "turbo build",
    "lint": "oxlint --max-warnings=200",
    "lint:fix": "oxlint --fix",
    "audit:jsx": "node scripts/audit-unbound-jsx.mjs",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "pnpm --filter fisioflow-web test",
    "test:components": "pnpm --dir apps/web exec vitest run --config vitest.config.ts src/components/**/*.test.tsx",
    "workers:type-check": "pnpm --filter @fisioflow/api type-check",
    "type-check": "pnpm --filter fisioflow-web type-check",
    "predeploy": "bash scripts/predeploy-check.sh",
    "predeploy:workers": "bash scripts/predeploy-check.sh --workers",
    "predeploy:all": "bash scripts/predeploy-check.sh --all",
    "deploy:api:staging": "bash scripts/cloudflare-env.sh pnpm --dir apps/api exec wrangler deploy --env staging",
    "deploy:api:production": "bash scripts/cloudflare-env.sh pnpm --dir apps/api exec wrangler deploy --env production",
    "deploy:web:staging": "pnpm --filter fisioflow-web build && bash scripts/cloudflare-env.sh pnpm --dir apps/api exec wrangler deploy --config ../../wrangler.toml --env staging",
    "deploy:web:production": "pnpm --filter fisioflow-web build && bash scripts/cloudflare-env.sh pnpm --dir apps/api exec wrangler deploy --config ../../wrangler.toml --env production",
    "deploy:staging": "pnpm deploy:web:staging && pnpm deploy:api:staging",
    "deploy:production": "pnpm deploy:web:production && pnpm deploy:api:production",
    "smoke:staging": "bash scripts/smoke-check.sh --web-url https://fisioflow-web-staging.rafalegollas.workers.dev --api-url https://fisioflow-api-staging.rafalegollas.workers.dev/api/health",
    "smoke:production": "bash scripts/smoke-check.sh --web-url https://www.moocafisio.com.br --api-url https://api-pro.moocafisio.com.br/api/health",
    "mobile:build:ios": "bash scripts/mobile-build.sh build:ios",
    "mobile:build:android": "bash scripts/mobile-build.sh build:android",
    "mobile:submit:ios": "bash scripts/mobile-build.sh submit:ios",
    "mobile:submit:android": "bash scripts/mobile-build.sh submit:android",
    "mobile:release": "bash scripts/mobile-build.sh release",
    "mobile:onboard": "node scripts/mobile-onboard-patients.mjs",
    "e2e": "cd e2e && npx playwright test",
    "test:resilience": "cd e2e && npx playwright test flows/resilience.spec.ts",
    "e2e:report": "cd e2e && npx playwright show-report",
    "prepare": "husky"
  },

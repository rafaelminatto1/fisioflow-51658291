	"scripts": {
		"predev": "pnpm --filter fisioflow-web predev",
		"dev": "pnpm --filter fisioflow-web dev",
		"dev:web": "pnpm --filter fisioflow-web dev",
		"dev:patient": "pnpm --filter fisioflow-patient-ios start",
		"dev:professional": "pnpm --filter @fisioflow/professional-app start",
		"dev:clean": "pnpm --filter fisioflow-web dev:clean",
		"dev:force": "pnpm --filter fisioflow-web dev:force",
		"clean:vite": "pnpm --filter fisioflow-web clean:vite",
		"clean:all": "pnpm store prune && rm -rf node_modules node_modules/.vite .vite dist apps/web/dist && pnpm install",
		"build": "pnpm --filter fisioflow-web build",
		"build:prod": "pnpm --filter fisioflow-web build:prod",
		"build:dev": "pnpm --filter fisioflow-web build:dev",
		"build:analyze": "pnpm --filter fisioflow-web build:analyze",
		"lint": "oxlint --quiet",
		"lint:fix": "oxlint --fix",
		"fmt": "oxfmt",
		"fmt:check": "oxfmt --check",
		"preview": "pnpm --filter fisioflow-web preview",
		"test": "pnpm --filter fisioflow-web test",
		"test:unit": "pnpm --filter fisioflow-web test:unit",
		"test:ui": "pnpm --filter fisioflow-web test:ui",
		"test:run": "pnpm --filter fisioflow-web test:run",
		"test:coverage": "pnpm --filter fisioflow-web test:coverage",
		"test:e2e": "pnpm --filter fisioflow-web test:e2e",
		"test:e2e:ci": "pnpm --filter fisioflow-web test:e2e:ci",
		"test:e2e:headed": "pnpm --filter fisioflow-web test:e2e:headed",
		"test:e2e:debug": "pnpm --filter fisioflow-web test:e2e:debug",
		"test:e2e:auth": "pnpm --filter fisioflow-web test:e2e:auth",
		"test:e2e:dashboard": "pnpm --filter fisioflow-web test:e2e:dashboard",
		"test:e2e:patients": "pnpm --filter fisioflow-web test:e2e:patients",
		"test:e2e:agenda": "pnpm --filter fisioflow-web test:e2e:agenda",
		"test:e2e:agenda-optimistic": "pnpm --filter fisioflow-web test:e2e:agenda-optimistic",
		"test:e2e:agenda-regression": "pnpm --filter fisioflow-web test:e2e:agenda-regression",
		"test:e2e:ui": "pnpm --filter fisioflow-web test:e2e:ui",
		"test:e2e:auto": "pnpm --filter fisioflow-web test:e2e:auto",
		"test:e2e:auto:ui": "pnpm --filter fisioflow-web test:e2e:auto:ui",
		"test:sprite": "testsprite test",
		"test:sprite:ui": "testsprite test --ui",
		"test:sprite:visual": "testsprite test --visual",
		"test:race": "node test-race-condition.mjs",
		"test:db-constraints": "node test-db-constraints.mjs",
		"test:pre-deploy": "npm run test:race 100 && npm run lint && npm run build",
		"hooks:install": "node scripts/pre-commit.mjs --install",
		"hooks:uninstall": "node scripts/pre-commit.mjs --uninstall",
		"cap:ios": "npx cap add ios",
		"cap:sync": "npm run build && npx cap sync",
		"cap:run:ios": "npx cap run ios",
		"cap:open:ios": "npx cap open ios",
		"gen:types": "json-schema-to-typescript -i schemas/dynamic_compare_metrics.schema.json -o src/generated/types/dynamic_compare_metrics.ts",
		"gen:zod": "json-schema-to-zod -i schemas/dynamic_compare_metrics.schema.json -o src/generated/zod/dynamic_compare_metrics.zod.ts",
		"gen:all": "npm run gen:types && npm run gen:zod",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:baseline": "node scripts/drizzle-baseline.mjs",
		"db:audit:schema": "node scripts/audit-neon-schema.mjs",
		"db:audit:worker-routes": "node scripts/audit-worker-route-schema.mjs",
		"db:apply:targeted-worker-schema": "node scripts/apply-targeted-schema-bundle.mjs",
		"db:apply:finalize-analytics-schema": "node scripts/apply-finalize-analytics-schema.mjs",
		"db:apply:next-worker-batch": "node scripts/apply-next-worker-schema-batch.mjs",
		"db:apply:clinical-analytics-batch": "node scripts/apply-clinical-analytics-batch.mjs",
		"db:apply:worker-route-residual-batch": "node scripts/apply-worker-route-residual-batch.mjs",
		"db:studio": "drizzle-kit studio",
		"db:seed:e2e": "node scripts/seed-e2e-data.cjs",
		"workers:dev": "pnpm --filter @fisioflow/api dev",
		"workers:deploy": "pnpm --filter @fisioflow/api run deploy",
		"workers:deploy:staging": "pnpm --filter @fisioflow/api deploy:staging",
		"workers:type-check": "pnpm --filter @fisioflow/api type-check",
		"deploy:web": "pnpm build && wrangler deploy",
		"deploy:all": "npm run deploy:web && npm run workers:deploy",
		"patient:start": "pnpm --filter fisioflow-patient-ios start",
		"patient:build:dev": "pnpm --filter fisioflow-patient-ios build:dev",
		"patient:build:preview": "pnpm --filter fisioflow-patient-ios build:preview",
		"patient:build:prod": "pnpm --filter fisioflow-patient-ios build:prod",
		"professional:start": "pnpm --filter @fisioflow/professional-app start",
		"professional:build:prod": "pnpm --filter @fisioflow/professional-app build:prod",
		"db:proxy": "bash ./scripts/db-proxy.sh",
		"verify": "node scripts/health-check.js",
		"migration:verify": "node scripts/verify-neon-cloudflare-migration.mjs",
		"check:console": "BASE_URL=http://127.0.0.1:8084 node scripts/check-console-errors-local.mjs",
		"android": "expo run:android",
		"ios": "expo run:ios",
		"changelog": "node src/lib/skills/fase1-changelog/generate-changelog.js --output=CHANGELOG.md",
		"changelog:week": "node src/lib/skills/fase1-changelog/generate-changelog.js --days=7",
		"changelog:since": "node src/lib/skills/fase1-changelog/generate-changelog.js",
		"test:e2e:critical": "pnpm --filter fisioflow-web test:e2e:critical",
		"test:e2e:deploy-gate": "pnpm --filter fisioflow-web test:e2e:deploy-gate",
		"test:e2e:a11y": "pnpm --filter fisioflow-web test:e2e:a11y",
		"type-check": "pnpm --filter fisioflow-web type-check",
		"perf:routes": "node scripts/perf-routes.mjs --output test-results/perf-routes-report.json",
		"test:components": "vitest run src/components/**/*.test.tsx",
		"test:hooks": "vitest run src/hooks/**/*.test.ts",
		"test:evolution:direct": "node test-direct-evolution.mjs",
		"test:evolution:module": "node test-notion-module-fetch.mjs",
		"analyze": "pnpm --filter fisioflow-web analyze",
		"lighthouse": "lighthouse http://localhost:4173 --view",
		"storybook": "pnpm --filter fisioflow-web storybook",
		"build-storybook": "pnpm --filter fisioflow-web build-storybook",
		"format": "pnpm --filter fisioflow-web format"
	},

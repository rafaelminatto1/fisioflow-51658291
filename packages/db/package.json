{
  "name": "@fisioflow/db",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.0.0"
  },
  "description": "Shared Drizzle schema — single source of truth for frontend and workers",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "import": "./src/schema/index.ts",
      "types": "./src/schema/index.ts",
      "default": "./src/schema/index.ts"
    }
  },
  "scripts": {
    "build": "echo \"no build\"",
    "lint": "oxlint",
    "type-check": "tsc --noEmit",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "recharts": "^2.15.4"
  },
  "devDependencies": {
    "vitest": "^4.1.5"
  }
}

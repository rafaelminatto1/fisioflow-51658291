# API Configuration
# Base URL for the API (without /api suffix - routes already include /api)
EXPO_PUBLIC_API_URL=https://api-pro.moocafisio.com.br

# Sentry Configuration
# A valid DSN starts with https://
EXPO_PUBLIC_SENTRY_DSN=https://your-public-key@sentry.io/your-project-id
SENTRY_AUTH_TOKEN=sntryu_your_auth_token_here

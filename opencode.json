{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "neon": {
      "type": "remote",
      "url": "https://mcp.neon.tech/mcp",
      "enabled": true
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?exaApiKey=REDACTED",
      "enabled": true
    },
    "websets": {
      "type": "remote",
      "url": "https://websetsmcp.exa.ai/mcp?exaApiKey=REDACTED",
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "enabled": true
    }
  }
}
{
	"$schema": "https://opencode.ai/config.json",
	"mcp": {
		"neon": {
			"type": "remote",
			"url": "https://mcp.neon.tech",
			"enabled": true
		},
		"shadcn": {
			"type": "local",
			"command": ["npx", "shadcn@latest", "mcp"],
			"enabled": true
		},
		"exa": {
			"type": "remote",
			"url": "https://mcp.exa.ai/mcp",
			"enabled": true,
			"headers": {
				"x-api-key": "d12af1da-4c1d-4665-a952-2bdfa6283d11"
			}
		},
		"chrome-devtools": {
			"type": "local",
			"command": ["npx", "-y", "chrome-devtools-mcp@latest"],
			"enabled": true
		}
	}
}

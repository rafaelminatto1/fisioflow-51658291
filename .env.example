# FisioFlow - Neon & Cloudflare Environment Variables

# DATABASE (Neon DB)
# Obtenha em: Neon Dashboard > Connection String
DATABASE_URL=postgresql://user:password@ep-project.region.aws.neon.tech/neondb?sslmode=require

# AUTH (Neon Auth)
# Obtenha em: Neon Dashboard > Auth > Configuration
VITE_NEON_AUTH_URL=https://your-auth-endpoint.neonauth.aws.neon.tech/neondb/auth
NEON_AUTH_JWKS_URL=https://your-auth-endpoint.neonauth.aws.neon.tech/neondb/auth/.well-known/jwks.json

# DATA API (Neon Data API) — opcional, habilite em Neon Console > Data API
# Oferece REST PostgREST-compatible direto ao banco, sem passar pelo Worker
# ATENÇÃO: configure RLS nas tabelas antes de habilitar em produção
VITE_NEON_DATA_API_URL=https://your-project.apirest.region.aws.neon.tech/neondb

# STORAGE (Cloudflare R2)
# Obtenha em: Cloudflare Dashboard > R2 > Bucket Details
R2_BUCKET_NAME=fisioflow-media
CLOUDFLARE_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key

# ANALYTICS (PostHog)
# Obtenha em: https://app.posthog.com > Project Settings > Project API Key
VITE_POSTHOG_KEY=phc_your_key_here
VITE_POSTHOG_HOST=https://us.i.posthog.com

# TESTSPRITE (AI Testing)
# Obtenha em: https://docs.testsprite.com/mcp/getting-started/overview
TESTSPRITE_API_KEY=your-testsprite-api-key-here

        { "name": "Achievement definitions", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/gamification/achievement-definitions", "host": ["{{baseUrl}}"], "path": ["api", "gamification", "achievement-definitions"] } } },
        { "name": "Admin stats", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/gamification/admin/stats", "host": ["{{baseUrl}}"], "path": ["api", "gamification", "admin", "stats"] } } }

        { "name": "Recall campaigns", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/marketing/recall-campaigns", "host": ["{{baseUrl}}"], "path": ["api", "marketing", "recall-campaigns"] } } },
        { "name": "LTV opportunities", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/marketing/ltv-maximizer/opportunities", "host": ["{{baseUrl}}"], "path": ["api", "marketing", "ltv-maximizer", "opportunities"] } } }

{
  "info": {
    "_postman_id": "56a0b57d-874f-4a21-9e6b-865078e8dfc3",
    "name": "FisioFlow API",
    "description": "Cloudflare Worker (Hono) API da FisioFlow. Base: {{baseUrl}}. Auth: Bearer {{jwt}} (Neon Auth). Selecione o environment 'FisioFlow — Prod' ou 'Local'. Endpoints derivados de apps/api/src/routes/*.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{jwt}}", "type": "string" }] },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('status < 500', () => pm.expect(pm.response.code).to.be.below(500));",
          "pm.test('responde em < 5s', () => pm.expect(pm.response.responseTime).to.be.below(5000));"
        ]
      }
    }
  ],
  "variable": [{ "key": "baseUrl", "value": "https://fisioflow-api.rafalegollas.workers.dev" }],
  "item": [
    {
      "name": "Health",
      "item": [
        { "name": "Health", "request": { "method": "GET", "auth": { "type": "noauth" }, "url": { "raw": "{{baseUrl}}/api/health", "host": ["{{baseUrl}}"], "path": ["api", "health"] } } },
        { "name": "Health Ready", "request": { "method": "GET", "auth": { "type": "noauth" }, "url": { "raw": "{{baseUrl}}/api/health/ready", "host": ["{{baseUrl}}"], "path": ["api", "health", "ready"] } } },
        { "name": "Health DB", "request": { "method": "GET", "auth": { "type": "noauth" }, "url": { "raw": "{{baseUrl}}/api/health/db", "host": ["{{baseUrl}}"], "path": ["api", "health", "db"] } } }
      ]
    },
    {
      "name": "Patients",
      "item": [
        { "name": "List patients", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/patients?status=active", "host": ["{{baseUrl}}"], "path": ["api", "patients"], "query": [{ "key": "status", "value": "active" }] } } },
        { "name": "Get patient", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/patients/{{patientId}}", "host": ["{{baseUrl}}"], "path": ["api", "patients", "{{patientId}}"] } } },
        { "name": "Create patient", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"Paciente Teste\",\n  \"email\": \"teste@example.com\",\n  \"phone\": \"11999999999\"\n}", "options": { "raw": { "language": "json" } } }, "url": { "raw": "{{baseUrl}}/api/patients", "host": ["{{baseUrl}}"], "path": ["api", "patients"] } } },
        { "name": "Update patient", "request": { "method": "PATCH", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"Nome Atualizado\"\n}", "options": { "raw": { "language": "json" } } }, "url": { "raw": "{{baseUrl}}/api/patients/{{patientId}}", "host": ["{{baseUrl}}"], "path": ["api", "patients", "{{patientId}}"] } } }
      ]
    },
    {
      "name": "Appointments",
      "item": [
        { "name": "List appointments", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/appointments", "host": ["{{baseUrl}}"], "path": ["api", "appointments"] } } },
        { "name": "Create appointment", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"start\": \"2026-06-20T14:00:00Z\",\n  \"durationMin\": 50\n}", "options": { "raw": { "language": "json" } } }, "url": { "raw": "{{baseUrl}}/api/appointments", "host": ["{{baseUrl}}"], "path": ["api", "appointments"] } } }
      ]
    },
    {
      "name": "Sessions",
      "item": [
        { "name": "List sessions", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/sessions?patientId={{patientId}}", "host": ["{{baseUrl}}"], "path": ["api", "sessions"], "query": [{ "key": "patientId", "value": "{{patientId}}" }] } } }
      ]
    },
    {
      "name": "Exercises",
      "item": [
        { "name": "List exercises", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/exercises", "host": ["{{baseUrl}}"], "path": ["api", "exercises"] } } },

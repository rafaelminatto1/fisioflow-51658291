{
  "info": {
    "name": "FisioFlow Health (monitor)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Coleção enxuta p/ monitor de uptime. Só endpoints públicos de health."
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('200 OK', () => pm.response.to.have.status(200));",
          "pm.test('< 3s', () => pm.expect(pm.response.responseTime).to.be.below(3000));"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/health",
          "host": ["{{baseUrl}}"],
          "path": ["api", "health"]
        }
      }
    },
    {
      "name": "Health Ready",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/health/ready",
          "host": ["{{baseUrl}}"],
          "path": ["api", "health", "ready"]
        }
      }
    },
    {
      "name": "Health DB",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/health/db",
          "host": ["{{baseUrl}}"],
          "path": ["api", "health", "db"]
        }
      }
    }
  ]
}
